{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for riders and drivers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["rider", "driver", "admin"] },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "Ride": {
      "title": "Ride",
      "description": "A ride request and current status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "riderId": { "type": "string" },
        "driverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "arriving", "active", "completed", "cancelled"] },
        "pickup": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "dropoff": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "fare": { "type": "number" },
        "distance": { "type": "string" },
        "duration": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "DriverLocation": {
      "title": "Driver Location",
      "description": "Real-time location and availability of a driver",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "isOnline": { "type": "boolean" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Ride transactions"
    },
    "/driverLocations/{driverId}": {
      "schema": "DriverLocation",
      "description": "Real-time driver tracking"
    }
  }
}
