rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.role == 'rider' || resource.data.role == 'driver');
      allow create, update: if isOwner(userId);
    }

    // Ride Rules
    match /rides/{rideId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // In production, refine this to resource.data.riderId == uid
      allow create: if isSignedIn() && request.resource.data.riderId == request.auth.uid;
      allow update: if isSignedIn(); // Simplified for MVP, in production add more checks
    }

    // Driver Location Rules
    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isOwner(driverId);
    }
  }
}
